<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/overlay_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:elevation="8dp"
    android:background="@android:color/transparent">

    <!-- Header: Alert Red bar with title and dismiss -->
    <RelativeLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#E63946"
        android:paddingStart="16dp"
        android:paddingEnd="8dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:text="Scam Warning"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btn_close"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Dismiss warning"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="#FFFFFF" />

    </RelativeLayout>

    <!-- Auto-dismiss countdown progress bar -->
    <ProgressBar
        android:id="@+id/countdown_progress"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:max="100"
        android:progress="100"
        android:progressDrawable="@android:color/white"
        android:background="#CC0000" />

    <!-- Body: Charcoal Black background with message and buttons -->
    <LinearLayout
        android:id="@+id/body"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1C1C1C"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="16dp">

        <TextView
            android:id="@+id/message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="This screen may contain a scam."
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/confidence_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0% detection confidence"
            android:textColor="#AAAAAA"
            android:textSize="13sp"
            android:layout_marginBottom="14dp" />

        <!-- Action buttons row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="start">

            <Button
                android:id="@+id/btn_dismiss"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="#FFD300"
                android:text="Dismiss"
                android:textColor="#1C1C1C"
                android:textSize="14sp"
                android:textStyle="bold"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:minWidth="0dp"
                android:layout_marginEnd="12dp" />

            <Button
                android:id="@+id/btn_open_app"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="@android:color/transparent"
                android:text="Open CanaryOS"
                android:textColor="#0077B6"
                android:textSize="14sp"
                android:textStyle="bold"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:minWidth="0dp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
